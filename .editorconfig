root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2
max_line_length = 100

[*.{md,mdx}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
max_line_length = 80

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{json,jsonc}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[.git*]
indent_style = tab

[*.txt]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[LICENSE]
indent_style = space
indent_size = 2

[VERSION]
insert_final_newline = false
