{
  // OpenCode configuration for CodeConductor projects.
  // Generated by: npx codeconductor init --target opencode
  //
  // This file is intentionally restrictive. The default posture is DENY.
  // Every permission that is not explicitly allowed must be confirmed by the
  // user or is denied outright. This is a deliberate design decision:
  // agents operating with broad permissions are unpredictable and dangerous.
  // Agents operating within tight constraints are auditable and trustworthy.
  "$schema": "https://opencode.ai/config.json",

  // Default model for all Conductor Agents.
  // See presets/opencode/README.md for complete model guide.
  //
  // CLAUDE MODELS (Anthropic):
  // - claude-opus-4-7: Complex reasoning, architecture, design
  // - claude-sonnet-4-6: General purpose, balanced
  // - claude-haiku-4-5-20251001: Fast, lightweight tasks
  //
  // OPENCODE GO MODELS (Chinese Providers):
  // - deepseek-v4-pro: DeepSeek — Reasoning complejo, arquitectura
  // - mimo-v2.5-pro: MiniMax — Implementación de código
  // - minimax-m2.7: MiniMax — Tareas equilibradas
  // - qwen-3.6-plus: Qwen — Rápido y eficiente
  // - kimi-k2.6: Kimi — Conversación natural
  //
  "model": "claude-sonnet-4-6",

  // Model overrides per agent (recommended):
  // Uncomment and customize as needed, or use agent frontmatter
  //
  // "orchestrator": { "claude": "claude-sonnet-4-6", "opencode-go": "deepseek-v4-pro" },
  // "architect": { "claude": "claude-opus-4-7", "opencode-go": "deepseek-v4-pro" },
  // "implementer": { "claude": "claude-sonnet-4-6", "opencode-go": "mimo-v2.5-pro" },
  // "tester": { "claude": "claude-sonnet-4-6", "opencode-go": "minimax-m2.7" },
  // "reviewer": { "claude": "claude-sonnet-4-6", "opencode-go": "qwen-3.6-plus" },
  // "task-coach": { "claude": "claude-haiku-4-5-20251001", "opencode-go": "qwen-3.6-plus" },
  // "docs": { "claude": "claude-haiku-4-5-20251001", "opencode-go": "qwen-3.6-plus" },
  // "repo-explorer": { "claude": "claude-haiku-4-5-20251001", "opencode-go": "qwen-3.6-plus" },

  "permission": {
    // READ — agents may read any file by default.
    // Secrets and credential files are explicitly denied regardless of location.
    // If an agent needs to read a secret, that is a workflow design problem,
    // not a permission problem.
    "read": {
      "default": "allow",
      "deny": [
        ".env",
        ".env.*",
        "secrets/**",
        "~/.ssh/**",
        "~/.aws/**",
        "~/.kube/**",
        "~/.gnupg/**",
        "~/.npmrc",
        "~/.pypirc",
      ],
    },

    // EDIT — agents must ask before modifying files.
    // Framework internals, OpenCode state, and credential files are denied
    // outright. Asking for every other edit keeps humans in the loop for
    // all writes. This is intentional: agents propose, humans approve.
    "edit": {
      "default": "ask",
      "deny": [".git/**", ".codeconductor/**", ".opencode/**", ".claude/**", "*.env", "*.env.*"],
    },

    // EXTERNAL DIRECTORY — agents must not access paths outside the project.
    // Granting cross-directory access enables privilege escalation and
    // exfiltration. Deny unconditionally.
    "external_directory": {
      "default": "deny",
    },

    // BASH — the highest-risk permission surface.
    // Structure: safe read-only operations are allowed; state-changing git
    // operations require confirmation; destructive operations are hard-denied.
    //
    // Denial patterns are intentionally broad. A missed pattern that allows
    // a destructive command is worse than an over-broad denial that requires
    // one extra confirmation.
    "bash": {
      "default": "ask",

      // Safe: these commands are read-only or idempotent test runners.
      // An agent can run them without interrupting the user.
      "allow": [
        "git status*",
        "git diff*",
        "git log*",
        "./gradlew test*",
        "./gradlew build*",
        "npm test*",
        "npm run lint*",
        // Python / Django / TDD — safe, read-only or idempotent
        "uv run pytest*",
        "make tests*",
        "make tests-coverage*",
        "make lint*",
        "make verifymigrations*",
        "uv run djlint --check*",
      ],

      // State-changing git operations that affect history or workspace.
      // Always require explicit user confirmation.
      "ask": [
        "git commit*",
        "git checkout*",
        "git switch*",
        // Django DB operations — require user confirmation
        "uv run python manage.py migrate_schemas*",
        "uv run python manage.py makemigrations*",
        "make migrate*",
        "make format*",
      ],

      // Hard denials. These commands can cause irreversible damage to the
      // repository, filesystem, or operating system. No exception path exists.
      "deny": [
        // Filesystem destruction
        "rm -rf *",
        // Privilege escalation
        "sudo *",
        "su *",
        // Dangerous permission changes
        "chmod 777 *",
        "chown *",
        // Disk-level operations — can destroy volumes
        "dd *",
        "mkfs *",
        "diskutil *",
        "mount *",
        "umount *",
        // System service management — out of scope for development agents
        "systemctl *",
        "launchctl *",
        // Remote code execution via pipe — never acceptable
        "curl * | sh",
        "curl * | bash",
        "wget * | sh",
        "wget * | bash",
        // Destructive git operations — these rewrite history or lose work
        "git push --force*",
        "git push -f*",
        "git rebase *",
        "git reset --hard *",
      ],
    },

    // WEBFETCH — agents must ask before fetching external URLs.
    // This prevents silent data exfiltration and unauthorized API calls.
    "webfetch": {
      "default": "ask",
    },

    // WEBSEARCH — agents must ask before issuing web searches.
    // Uncontrolled searches can leak internal context (class names, file
    // paths, API keys embedded in queries). Confirm before searching.
    "websearch": {
      "default": "ask",
    },

    // TASK — sub-agent spawning requires confirmation.
    // Each task is a new agent with its own permission surface. Spawning
    // without review can bypass the intent of this policy.
    "task": {
      "default": "ask",
    },

    // SKILL — skill invocations require confirmation.
    // Skills extend agent capabilities. Confirm before activating.
    "skill": {
      "default": "ask",
    },
  },
}
