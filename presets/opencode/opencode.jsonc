{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/qwen3.7-max",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "secrets/**": "deny",
      "~/.ssh/**": "deny",
      "~/.aws/**": "deny",
      "~/.kube/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.npmrc": "deny",
      "~/.pypirc": "deny"
    },
    "edit": {
      "*": "ask",
      ".git/**": "deny",
      ".codeconductor/**": "deny",
      ".opencode/**": "deny",
      ".claude/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "external_directory": "deny",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "./gradlew test*": "allow",
      "./gradlew build*": "allow",
      "npm test*": "allow",
      "npm run lint*": "allow",
      "uv run pytest*": "allow",
      "make tests*": "allow",
      "make tests-coverage*": "allow",
      "make lint*": "allow",
      "make verifymigrations*": "allow",
      "uv run djlint --check*": "allow",
      "git add*": "ask",
      "git commit*": "ask",
      "git push*": "ask",
      "git pull*": "ask",
      "git checkout*": "ask",
      "git switch*": "ask",
      "uv run python manage.py migrate_schemas*": "ask",
      "uv run python manage.py makemigrations*": "ask",
      "make migrate*": "ask",
      "make format*": "ask",
      "rm -rf *": "deny",
      "sudo *": "deny",
      "su *": "deny",
      "chmod 777 *": "deny",
      "chown *": "deny",
      "dd *": "deny",
      "mkfs *": "deny",
      "diskutil *": "deny",
      "mount *": "deny",
      "umount *": "deny",
      "systemctl *": "deny",
      "launchctl *": "deny",
      "curl * | sh": "deny",
      "curl * | bash": "deny",
      "wget * | sh": "deny",
      "wget * | bash": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "git rebase *": "deny",
      "git reset --hard *": "deny"
    },
    "webfetch": "ask",
    "websearch": "ask",
    "skill": "ask"
  }
}
